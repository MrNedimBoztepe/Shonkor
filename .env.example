# -------------------------------------------------------------
# Shonkor Docker Environment Configuration
# -------------------------------------------------------------
# Rename this file to '.env' and adjust the paths to your needs.

# TARGET_PROJECTS_DIR defines which folder on your host machine 
# should be mounted into the Shonkor container at /projects.
# 
# Recommendation (Alternative C): Point this to a parent directory 
# that contains multiple projects, so you can switch between them 
# in the Shonkor UI without restarting Docker.
# 
# Example Windows: C:\Projects
# Example Mac/Linux: ~/workspace
# Default if empty: ./ (The folder where docker-compose.yml is located)
TARGET_PROJECTS_DIR=C:\Projects
